# MongoDB
MONGO_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=girogirotondo

# JWT (legacy dev-mode fallback)
JWT_SECRET=replace-with-a-256-bit-random-string

# Firebase Admin SDK (from Firebase Console → Project settings → Service accounts)
FIREBASE_PROJECT_ID=girogirotondo
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@girogirotondo.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=girogirotondo.firebasestorage.app

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# Set to "true" to allow custom JWT fallback (development only)
DEV_MODE=false

# Vercel sets this automatically in production
# VERCEL_ENV=production
