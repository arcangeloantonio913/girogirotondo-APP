# ============================================================
# Girogirotondo — Backend Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ============================================================

# --- MongoDB Atlas ---
# Get from: MongoDB Atlas → Cluster → Connect → Drivers
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
DB_NAME=girogirotondo

# --- JWT (legacy dev fallback only) ---
# Generate: openssl rand -hex 32
# Required only if DEV_MODE=true. Not used in production with Firebase Auth.
JWT_SECRET=

# --- Firebase Admin SDK ---
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# --- Dev Mode ---
# MUST be false in production. Enables custom JWT fallback for local testing only.
DEV_MODE=false

# --- Sentry (error monitoring) ---
# Get from: sentry.io → Project → Settings → SDK Setup
SENTRY_DSN=
