# ============================================================
# Girogirotondo — Frontend Environment Variables (CRA/CRACO)
# Copia in .env.local per sviluppo locale.
# Per produzione: imposta in Vercel Dashboard → Settings → Environment Variables
# NEVER commitare .env.local
# ============================================================

# --- Backend API URL ---
REACT_APP_BACKEND_URL=https://your-backend.railway.app

# --- Firebase Web SDK ---
# Ottieni da: Firebase Console → Impostazioni progetto → Le tue app → Web → Configurazione
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# --- Sentry (error monitoring) ---
# Ottieni da: sentry.io → Progetto → Settings → SDK Setup → Client Keys
REACT_APP_SENTRY_DSN=
